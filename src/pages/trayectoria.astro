---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Trayectoria Académica | Simón Diaz | Portafolio TIC" description="Trayectoria académica de Simón Diaz en el Profesorado de Educación Secundaria en TIC (ISPARM). Informes, proyectos y artículos de materias como Práctica I, Comunicación I, Sistemas Operativos y más.">
    <section id="trayectoria">
        <div class="container">
            <h2>Trayectoria Académica</h2>
            <p class="subtitle" style="text-align: center; margin: -2rem auto 3rem; max-width: 750px;">
                Un registro detallado de algunas materias cursadas, proyectos prácticos y artículos académicos más
                destacados que se ha desarrollado en mi formación académica.
            </p>

            <div class="blog-search-trigger">
                <button id="search-blog-btn" class="blog-search-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.3-4.3" />
                    </svg>
                    <span>Buscar artículos en mi trayectoria...</span>
                </button>
            </div>

            <!-- Timeline Stepper Component -->
            <div class="timeline-container">
                <div class="timeline-steps">
                    <div class="timeline-progress-bar">
                        <div class="timeline-progress" id="timeline-progress"></div>
                    </div>
                    <button class="timeline-step active" data-stage="1">
                        <span class="step-dot"></span>
                        <span class="step-label">1º Año</span>
                        <span class="step-sublabel">Cursando (2026)</span>
                    </button>
                    <button class="timeline-step" data-stage="2">
                        <span class="step-dot"></span>
                        <span class="step-label">2º Año</span>
                        <span class="step-sublabel">Plan de Estudios</span>
                    </button>
                    <button class="timeline-step" data-stage="3">
                        <span class="step-dot"></span>
                        <span class="step-label">3º Año</span>
                        <span class="step-sublabel">Plan de Estudios</span>
                    </button>
                    <button class="timeline-step" data-stage="4">
                        <span class="step-dot"></span>
                        <span class="step-label">4º Año</span>
                        <span class="step-sublabel">Plan de Estudios</span>
                    </button>
                </div>
            </div>

            <div class="grid">
                <!-- 1º Año - Materias Cursadas / En Cursado -->
                <a href="/trayectoria/practica-1" class="card-link" data-stage="1">
                    <div class="card blog-card">
                        <div class="badge subject-badge">Práctica Profesional</div>
                        <h3>Práctica I</h3>
                        <p>Primer acercamiento al campo educativo mediante observaciones, análisis institucional y
                            reflexión sobre el rol del docente.</p>
                        <span class="read-more">Ver materia y artículos &rarr;</span>
                    </div>
                </a>

                <a href="/trayectoria/comunicacion-1" class="card-link" data-stage="1">
                    <div class="card blog-card">
                        <div class="badge subject-badge">Habilidades Blandas</div>
                        <h3>Comunicación I</h3>
                        <p>Desarrollo de habilidades comunicativas y análisis de la comunicación como proceso
                            fundamental para la educación y la construcción del conocimiento.</p>
                        <span class="read-more">Ver materia y artículos &rarr;</span>
                    </div>
                </a>

                <a href="/trayectoria/sistemas-operativos" class="card-link" data-stage="1">
                    <div class="card blog-card">
                        <div class="badge subject-badge">Sistemas y Software</div>
                        <h3>Sistemas Operativos</h3>
                        <p>Estudio del funcionamiento de los sistemas operativos y su rol en la administración de
                            recursos, procesos y dispositivos informáticos.</p>
                        <span class="read-more">Ver materia y artículos &rarr;</span>
                    </div>
                </a>

                <a href="/trayectoria/arquitectura" class="card-link" data-stage="1">
                    <div class="card blog-card">
                        <div class="badge subject-badge">Hardware y Sistemas</div>
                        <h3>Arquitectura de Ordenadores Personales</h3>
                        <p>Comprensión de los componentes y la lógica que hacen posible el funcionamiento de
                            computadoras y sistemas tecnológicos modernos.</p>
                        <span class="read-more">Ver materia y artículos &rarr;</span>
                    </div>
                </a>

                <a href="/trayectoria/taller-ole" class="card-link" data-stage="1">
                    <div class="card blog-card">
                        <div class="badge subject-badge">Comprensión y Escritura</div>
                        <h3>Taller de Oralidad, Lectura y Escritura</h3>
                        <p>Desarrollo de habilidades de lectura, escritura y oralidad para la construcción y
                            comunicación del conocimiento académico.</p>
                        <span class="read-more">Ver materia y artículos &rarr;</span>
                    </div>
                </a>

                <a href="/trayectoria/actividades-complementarias" class="card-link" data-stage="1">
                    <div class="card blog-card">
                        <div class="badge subject-badge">Formación Complementaria</div>
                        <h3>Actividades Complementarias</h3>
                        <p>Participación en proyectos, eventos y actividades que contribuyen a la formación docente más
                            allá de las asignaturas de la carrera.</p>
                        <span class="read-more">Ver formación complementaria &rarr;</span>
                    </div>
                </a>

