---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Videos y Recursos Digitales | Simón Diaz" description="Tutoriales y recursos audiovisuales sobre herramientas digitales, inteligencia artificial y buenas prácticas tecnológicas de manera accesible.">
    <section id="videos">
        <div class="container">
            <h1>Tutoriales Destacados</h1>
            <p class="subtitle" style="text-align: center; margin: -2rem auto 3rem; max-width: 750px;">
Esta sección reúne contenidos audiovisuales desarrollados para acercar herramientas digitales, inteligencia artificial y buenas prácticas tecnológicas de manera accesible.
            </p>
            <div class="grid">
                <!-- Videos cargados dinámicamente desde YouTube API -->
                <p style="grid-column: 1/-1; text-align: center; color: var(--accent);">Cargando últimos tutoriales...</p>
            </div>
        </div>
    </section>
    
    <script src="/assets/js/youtube.js" is:inline></script>
</Layout>
