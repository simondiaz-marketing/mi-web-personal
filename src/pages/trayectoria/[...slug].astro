---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articulos = await getCollection('trayectoria');
  return articulos.map(articulo => ({
    params: { slug: articulo.slug },
    props: { articulo },
  }));
}

const { articulo } = Astro.props;
const { Content } = await articulo.render();

// Obtener artículos recomendados de la misma sección (subject)
const allArticulos = await getCollection('trayectoria');
const recommended = allArticulos
  .filter(a => a.data.subject === articulo.data.subject && a.slug !== articulo.slug)
  .slice(0, 3);
---

<Layout title={`${articulo.data.title} | Simón Diaz`} description={articulo.data.description} bodyClass="article-page">
    <div class="article-content" style="padding-top: 8rem; max-width: 800px; margin: 0 auto; padding-bottom: 4rem;">
        <a href="javascript:history.back()" class="back-link" style="color: var(--accent-primary); text-decoration: none; font-weight: 600;">&larr; Volver</a>
        
        <header class="article-header" style="margin-top: 2rem; margin-bottom: 3rem;">
            <div class="badge subject-badge" style="display: inline-block; padding: 0.4rem 0.8rem; background: rgba(0, 242, 255, 0.1); color: var(--accent-primary); border-radius: 20px; font-size: 0.85rem; font-weight: 600; margin-bottom: 1rem;">{articulo.data.badge}</div>
            <h1 style="font-size: 2.5rem; margin-bottom: 1.5rem;">{articulo.data.title}</h1>
            <div class="author-info" style="display: flex; align-items: center; gap: 1rem;">
                <img src="/assets/img/perfil.jpg" alt="Simón Diaz" class="author-img" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover;">
                <div>
                    <strong style="display: block;">Simón Diaz</strong>
                    <span style="font-size: 0.9rem; color: var(--text-dim);">Publicado en {articulo.data.date}</span>
                </div>
            </div>
        </header>

        <div class="article-body">
            <Content />
        </div>

        {recommended.length > 0 && (
            <div class="recommended-articles" style="margin-top: 5rem; padding-top: 3rem; border-top: 1px solid var(--glass-border);">
                <h2 style="font-size: 1.8rem; margin-bottom: 2rem; color: var(--text);">Artículos de la misma sección</h2>
                <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
                    {recommended.map(rec => (
                        <a href={`/trayectoria/${rec.slug}`} class="card-link" style="text-decoration: none;">
                            <div class="card blog-card" style="height: 100%;">
                                <div class="badge subject-badge">{rec.data.badge}</div>
                                <h3 style="margin: 1rem 0; font-size: 1.3rem;">{rec.data.title}</h3>
                                <p style="color: var(--text-dim); margin-bottom: 1.5rem; font-size: 0.95rem;">{rec.data.description}</p>
                                <span class="read-more" style="color: var(--accent-primary); font-weight: 600;">Leer artículo &rarr;</span>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        )}
    </div>
</Layout>
