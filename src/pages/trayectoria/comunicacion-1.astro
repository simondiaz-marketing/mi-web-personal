---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Comunicación I | Trayectoria Académica | Simón Diaz" description="Artículos desarrollados para la materia Comunicación I por Simón Diaz.">
    <section id="subject-detail">
        <div class="container" style="padding-top: 6rem; padding-bottom: 4rem;">
            <a href="/trayectoria" class="back-link" style="display: inline-block; margin-bottom: 2rem; color: var(--accent-primary); text-decoration: none; font-weight: 600;">&larr; Volver a Trayectoria</a>
            
            <h2 style="text-align: left; margin-bottom: 1rem;">Comunicación I</h2>
            <p class="subtitle" style="color: var(--text-dim); margin-bottom: 4rem;">
                Desarrollo de habilidades comunicativas y análisis de la comunicación como proceso fundamental para la educación y la construcción del conocimiento.
            </p>

            <div class="grid">
                <p style="grid-column: 1/-1; text-align: center; color: var(--text-dim); margin: 3rem 0; font-size: 1.1rem;">Próximamente se publicarán los artículos de esta materia.</p>
            </div>
        </div>
    </section>
</Layout>
