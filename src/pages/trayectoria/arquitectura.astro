---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Arquitectura de Ordenadores Personales | Trayectoria Académica | Simón Diaz" description="Artículos e informes sobre Arquitectura de Computadoras por Simón Diaz.">
    <section id="subject-detail">
        <div class="container" style="padding-top: 6rem; padding-bottom: 4rem;">
            <a href="/trayectoria" class="back-link" style="display: inline-block; margin-bottom: 2rem; color: var(--accent-primary); text-decoration: none; font-weight: 600;">&larr; Volver a Trayectoria</a>
            
            <h2 style="text-align: left; margin-bottom: 1rem;">Arquitectura de Ordenadores Personales</h2>
            <p class="subtitle" style="color: var(--text-dim); margin-bottom: 4rem;">
                Comprensión de los componentes y la lógica que hacen posible el funcionamiento de computadoras y sistemas tecnológicos modernos.
            </p>

            <div class="grid">
                <p style="grid-column: 1/-1; text-align: center; color: var(--text-dim); margin: 3rem 0; font-size: 1.1rem;">Próximamente se publicarán los análisis y trabajos de esta materia.</p>
            </div>
        </div>
    </section>
</Layout>
