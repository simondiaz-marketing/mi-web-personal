---
export interface Props {
	title: string;
	description?: string;
	bodyClass?: string;
}

const { title, description = "Portafolio académico de Simón Diaz, estudiante del Profesorado de Educación Secundaria en Tecnologías de la Información y la Comunicación en el ISPARM.", bodyClass = "" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content="/assets/img/perfil.jpg">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:title" content={title}>
    <meta property="twitter:description" content={description}>
    <meta property="twitter:image" content="/assets/img/perfil.jpg">

    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <link rel="stylesheet" href="/assets/css/styles.css">
</head>
<body class={bodyClass}>
    <div id="canvas-container"></div>

    <nav>
        <div class="container nav-container">
            <div class="logo">SIMÓN DIAZ</div>
            <ul class="nav-links">
                <li><a href="/">Inicio</a></li>
                <li><a href="/sobre-mi">Sobre Mí</a></li>
                <li><a href="/trayectoria">Trayectoria Académica</a></li>
                <li><a href="/videos">Videos</a></li>
                <li><a href="/contacto">Contacto</a></li>
                <li class="search-trigger-nav"><a href="javascript:void(0)" id="search-nav-btn"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></a></li>
            </ul>
        </div>
    </nav>

    <!-- Search Overlay -->
    <div id="search-overlay" class="search-overlay">
        <div class="search-container">
            <div class="search-header">
                <input type="text" id="search-input" placeholder="Buscar artículos o videos..." autocomplete="off">
                <button id="close-search">&times;</button>
            </div>
            <div id="search-results" class="search-results">
                <!-- Dynamic results here -->
            </div>
        </div>
    </div>

    <slot />

    <footer>
        <div class="container" style="text-align: center;">
            <p style="margin-bottom: 0.5rem;">Contacto: <a href="#" class="secure-email" data-u="simondiaz.contacto" data-d="gmail.com" style="color: var(--accent); text-decoration: none;">Simondiaz.contacto@gmail.com</a></p>
            <p>&copy; 2026 Simón Diaz. Todos los derechos reservados.</p>
        </div>
    </footer>

    <script type="module" src="/assets/js/main.js" is:inline></script>
</body>
</html>
